# ==============================
# J.A.R.V.I.S. Local AI Agent
# Copy this file to .env and fill values.
# ==============================

# --- Core LLM ---
JARVIS_API_KEY=sk-local-key
JARVIS_MODEL=local-model
JARVIS_BASE_URL=http://localhost:1234/v1
JARVIS_LLM_TEMPERATURE=0.2
JARVIS_LLM_TIMEOUT=30
JARVIS_MAX_TOOL_STEPS=5

# --- Voice / Audio ---
JARVIS_TTS_VOICE=ru-RU-SvetlanaNeural
JARVIS_STT_LANGUAGE=ru

# --- Faster-Whisper ---
JARVIS_WHISPER_MODEL=base
JARVIS_WHISPER_DEVICE=auto
JARVIS_WHISPER_COMPUTE_TYPE=int8
HF_TOKEN=

# --- Server / Security ---
# API key used by FastAPI/WebSocket auth layer
# (in many setups can match JARVIS_API_KEY)
# JARVIS_SERVER_API_KEY=

# --- Runtime paths ---
JARVIS_RULES_PATH=
JARVIS_TRIGGER_DIR=

# --- Local debugging ---
JARVIS_DEBUG_TEXT_MODE=false
